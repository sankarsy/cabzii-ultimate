# Copy to .env.local — use ONE backend block only (do not duplicate keys).

# Local dev:
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Production (comment local lines above when using live API):
# BACKEND_URL=https://api.cabzii.in
# NEXT_PUBLIC_BACKEND_URL=https://api.cabzii.in

GOOGLE_SITE_VERIFICATION=

GOOGLE_MAPS_API_KEY=

# OpenStreetMap address search (Nominatim) — free, used by default
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=CabziiCabBooking/1.0 (contact@cabzii.in)

# OpenRouteService — driving distance & route (optional; falls back to estimate)
OPENROUTESERVICE_API_KEY=
