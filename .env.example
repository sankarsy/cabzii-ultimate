# Next.js frontend (set this in Vercel to your deployed backend URL)
BACKEND_URL=http://localhost:8000
# Optional fallback used by some production server routes
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Google Places autocomplete (optional — admin locations still work without it)
GOOGLE_MAPS_API_KEY=

# Public backend URL (required for cab images: /uploads/... served from API)
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Auth: JWT is issued by backend only — set JWT_SECRET on backend, not here.
# Login uses httpOnly cookie cabzii_token (set via /api/auth/session after OTP).
