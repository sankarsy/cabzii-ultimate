# Backend API base URL.
# PRODUCTION: point both to the deployed backend at https://api.cabzii.in
# LOCAL DEV: use http://localhost:8000
#
# BACKEND_URL is used server-side by Next.js API routes / RSC data fetching.
BACKEND_URL=https://api.cabzii.in
# NEXT_PUBLIC_BACKEND_URL is exposed to the browser (used to build cab/upload
# image URLs like https://api.cabzii.in/uploads/...). Must be public.
NEXT_PUBLIC_BACKEND_URL=https://api.cabzii.in

# Google Search Console HTML tag verification (paste content value only, not full meta tag)
GOOGLE_SITE_VERIFICATION=

# Google Maps: Places Autocomplete, Geocoding, Distance Matrix (pincode + address search)
# Enable in Google Cloud: Places API, Geocoding API, Distance Matrix API
GOOGLE_MAPS_API_KEY=

# Auth: JWT is issued by backend only — set JWT_SECRET on backend, not here.
# Login uses httpOnly cookie cabzii_token (set via /api/auth/session after OTP).
